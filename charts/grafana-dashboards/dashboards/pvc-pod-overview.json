{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"}},
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count(kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total PVCs",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "unit": "short"}},
      "gridPos": {"h": 3, "w": 4, "x": 4, "y": 1},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count(kube_persistentvolumeclaim_status_phase{phase=\"Bound\", namespace=~\"$namespace\"} == 1) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Bound PVCs",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 3, "w": 4, "x": 8, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count(\n  kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  / kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  * 100 > 80\n) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "PVCs > 80% Full",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 3, "w": 4, "x": 12, "y": 1},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count(\n  kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  / kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  * 100 > 95\n) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "PVCs > 95% Full",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "purple", "mode": "fixed"}, "unit": "bytes"}},
      "gridPos": {"h": 3, "w": 4, "x": 16, "y": 1},
      "id": 6,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total PVC Capacity",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "orange", "mode": "fixed"}, "unit": "bytes"}},
      "gridPos": {"h": 3, "w": 4, "x": 20, "y": 1},
      "id": 7,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total PVC Used",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 4},
      "id": 10,
      "title": "PVC Usage",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 11,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sort_desc(\n  kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  / kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  * 100\n)",
          "instant": true,
          "legendFormat": "{{cluster_region}} / {{namespace}} / {{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "title": "Current PVC Usage % (sorted)",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 12,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n/ kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n* 100",
          "legendFormat": "{{cluster_region}} / {{namespace}} / {{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "title": "PVC Usage % Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 20,
      "title": "Pod → PVC → Node Mapping",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto", "inspect": false}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Used"},
            "properties": [{"id": "unit", "value": "bytes"}]
          },
          {
            "matcher": {"id": "byName", "options": "Capacity"},
            "properties": [{"id": "unit", "value": "bytes"}]
          },
          {
            "matcher": {"id": "byName", "options": "Usage %"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 14},
      "id": 21,
      "options": {
        "footer": {"enablePagination": true},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Usage %"}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n/ kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n* 100",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        }
      ],
      "title": "Pod → PVC → Node Detail",
      "transformations": [
        {"id": "merge", "options": {}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "endpoint": true,
              "job": true,
              "metrics_path": true,
              "service": true
            },
            "renameByName": {
              "Value #A": "Used",
              "Value #B": "Capacity",
              "Value #C": "Usage %",
              "cluster_region": "Region",
              "instance": "Node",
              "namespace": "Namespace",
              "persistentvolumeclaim": "PVC",
              "pod": "Pod"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 30,
      "title": "Inode Usage",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 25},
      "id": 31,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sort_desc(\n  kubelet_volume_stats_inodes_used{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  / kubelet_volume_stats_inodes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n  * 100\n)",
          "instant": true,
          "legendFormat": "{{cluster_region}} / {{namespace}} / {{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "title": "Current Inode Usage % (sorted)",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 25},
      "id": 32,
      "options": {
        "legend": {"calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "asc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kubelet_volume_stats_inodes_free{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}",
          "legendFormat": "{{cluster_region}} / {{namespace}} / {{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "title": "Inodes Free Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "id": 40,
      "title": "Node Disk IO — Correlated by Region (block-device level)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 33},
      "id": 41,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_disk_read_bytes_total{cluster_region=~\"$cluster_region\", device!~\"loop.*|dm-.*\"}[5m])",
          "legendFormat": "{{cluster_region}} / {{instance}} / {{device}}",
          "refId": "A"
        }
      ],
      "title": "Node Disk Read Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 33},
      "id": 42,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_disk_written_bytes_total{cluster_region=~\"$cluster_region\", device!~\"loop.*|dm-.*\"}[5m])",
          "legendFormat": "{{cluster_region}} / {{instance}} / {{device}}",
          "refId": "A"
        }
      ],
      "title": "Node Disk Write Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "thresholdsStyle": {"mode": "line"}
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 80}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 33},
      "id": 43,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_disk_io_time_seconds_total{cluster_region=~\"$cluster_region\", device!~\"loop.*|dm-.*\"}[5m]) * 100",
          "legendFormat": "{{cluster_region}} / {{instance}} / {{device}}",
          "refId": "A"
        }
      ],
      "title": "Node Disk IO Utilization %",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41},
      "id": 50,
      "title": "Container Filesystem Activity — closest proxy for PVC IO per pod",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 42},
      "id": 51,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(container_fs_reads_bytes_total{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", container!=\"\", container!=\"POD\"}[5m])",
          "legendFormat": "{{namespace}} / {{pod}} / {{container}}",
          "refId": "A"
        }
      ],
      "title": "Container FS Read Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 42},
      "id": 52,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(container_fs_writes_bytes_total{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", container!=\"\", container!=\"POD\"}[5m])",
          "legendFormat": "{{namespace}} / {{pod}} / {{container}}",
          "refId": "A"
        }
      ],
      "title": "Container FS Write Throughput",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 50},
      "id": 60,
      "title": "Capacity Predictions",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Current %"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "In 24h %"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "In 7d %"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 51},
      "id": 61,
      "options": {
        "footer": {"enablePagination": true},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "In 7d %"}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kubelet_volume_stats_used_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n/ kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n* 100",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "(\n  1 - clamp_min(\n    predict_linear(kubelet_volume_stats_available_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}[6h], 86400),\n    0\n  )\n  / kubelet_volume_stats_capacity_bytes{cluster_region=~\"$cluster_region\", namespace=~\"$namespace\", persistentvolumeclaim=~\"$pvc\"}\n) * 100",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
