          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 37
      },
      "id": 20,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "rate(wireguard_received_bytes_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "RX rate per VM (stacked)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Bytes sent per peer per second (outgoing tunnel traffic).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 37
      },
      "id": 21,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "rate(wireguard_sent_bytes_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "TX rate per VM (stacked)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Cumulative bytes transferred per VM since wg-quick service started.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "displayMode": "color-background-solid"
