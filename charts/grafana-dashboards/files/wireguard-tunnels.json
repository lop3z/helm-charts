      "id": 22,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Received"
          }
        ]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "wireguard_received_bytes_total{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "expr": "wireguard_sent_bytes_total{instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        }
      ],
      "title": "Cumulative bytes per VM (table)",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "instance",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "device 1": true,
              "device 2": true,
              "job 1": true,
              "job 2": true,
              "public_key 1": true,
              "public_key 2": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "cluster_region 2": true
            },
            "renameByName": {
              "instance": "VM",
              "Value #A": "Received",
              "Value #B": "Sent",
              "cluster_region 1": "Region"
            }
          }
        }
      ],
      "type": "table"
    },
    {
